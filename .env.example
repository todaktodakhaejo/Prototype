# 프로토타입 KPI 수집 설정 (Vite 환경변수)
# 실제 값은 .env.local 에 넣으세요 (git에 안 올라감). 변경 후 dev 서버 재시작 필요.

# KPI 수집 on/off. 'false'면 비활성(기분 척도·계측 전부 끔). 기본 켜짐.
VITE_KPI_ENABLED=true

# 라운드 종료마다 KPI 1건을 POST할 엔드포인트.
# 구글 시트 자동 적재: docs/kpi-google-sheet.gs 참고 → 배포한 Apps Script 웹앱 URL을 여기에.
# 비워두면 전송하지 않고 브라우저 localStorage(heulim.kpi.rounds)에만 쌓임.
VITE_KPI_ENDPOINT=
